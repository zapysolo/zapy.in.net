---
import { skillCategories } from '@/data/skills';

const ACTIVE_ICON =
  'M400 480H48c-26.51 0-48-21.49-48-48V80c0-26.51 21.49-48 48-48h352c26.51 0 48 21.49 48 48v352c0 26.51-21.49 48-48 48zm-204.686-98.059l184-184c6.248-6.248 6.248-16.379 0-22.627l-22.627-22.627c-6.248-6.248-16.379-6.249-22.628 0L184 302.745l-70.059-70.059c-6.248-6.248-16.379-6.248-22.628 0l-22.627 22.627c-6.248 6.248-6.248 16.379 0 22.627l104 104c6.249 6.25 16.379 6.25 22.628.001z';
const INACTIVE_ICON =
  'M400 32H48C21.5 32 0 53.5 0 80v352c0 26.5 21.5 48 48 48h352c26.5 0 48-21.5 48-48V80c0-26.5-21.5-48-48-48z';

const codeLines = [
  { num: 1, content: '/**', type: 'comment' },
  { num: 2, content: '* About Nikhil Patil', type: 'heading' },
  { num: 3, content: '* Welcome to my portfolio!', type: 'teal' },
  { num: 4, content: '*', type: 'comment' },
  { num: 5, content: '* Bachelors in Engineering CS', type: 'teal-highlight' },
  { num: 6, content: '* Currently pursuing Masters in AI', type: 'teal-highlight' },
  { num: 7, content: '*/', type: 'comment' },
];
---

<section
  id="about"
  class="flex-1 bg-vs-bg-secondary px-4 md:px-6 lg:px-8 py-12 min-h-screen"
  aria-labelledby="about-heading"
>
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_350px] gap-4 sm:gap-8">

      <!-- Code editor card -->
      <div class="bg-vs-bg-card rounded-lg shadow-xl overflow-hidden">
        <div class="bg-vs-bg-card-hover p-2 flex items-center" aria-hidden="true">
          <div class="flex space-x-2">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
          </div>
          <span class="ml-4 text-gray-400 text-sm font-mono">AboutMe.tsx</span>
        </div>

        <div class="p-4 sm:p-6 font-mono text-xs sm:text-sm" role="region" aria-label="About me">
          <h2 id="about-heading" class="sr-only">About Me</h2>
          {
            codeLines.map((line) => (
              <div class="flex group hover:bg-vs-bg-card-hover transition-colors duration-150">
                <span class="flex-shrink-0 w-8 text-gray-500 opacity-50 select-none">
                  {line.num}
                </span>
                <div class="flex-1 min-w-0 py-0.5">
                  {line.type === 'comment' && (
                    <span class="text-gray-400">{line.content}</span>
                  )}
                  {line.type === 'heading' && (
                    <span>
                      <span class="text-vs-teal">* </span>
                      <span class="text-xl sm:text-3xl font-semibold tracking-tight text-white">
                        About Nikhil Patil
                      </span>
                    </span>
                  )}
                  {line.type === 'teal' && (
                    <span class="text-vs-teal">{line.content}</span>
                  )}
                  {line.type === 'teal-highlight' && (
                    <span class="text-vs-teal">
                      {line.content.split(/(CS|Masters in AI)/g).map((part) =>
                        part === 'CS' || part === 'Masters in AI' ? (
                          <span class="text-[#A9D6E5] font-bold">{part}</span>
                        ) : (
                          part
                        ),
                      )}
                    </span>
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Skills panel -->
      <div class="space-y-4 sm:space-y-6">
        {
          skillCategories.map((category) => (
            <div class="bg-vs-bg-card p-3 sm:p-6 rounded-lg shadow-xl">
              <p class="text-gray-400 mb-3 sm:mb-4 text-xs sm:text-sm font-mono border-b border-gray-700 pb-2">
                {category.label}
              </p>
              <ul class="grid grid-cols-1 xs:grid-cols-2 gap-1 sm:gap-2" role="list">
                {category.skills.map((skill) => (
                  <li class="flex items-center p-1.5 sm:p-2 hover:bg-vs-bg-card-hover rounded transition-colors duration-200">
                    <svg
                      stroke="currentColor"
                      fill="currentColor"
                      stroke-width="0"
                      viewBox="0 0 448 512"
                      class:list={[
                        'min-w-[14px] sm:min-w-[16px] mr-2 shrink-0',
                        skill.active ? 'text-vs-teal' : 'text-gray-600',
                      ]}
                      height="1em"
                      width="1em"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <path d={skill.active ? ACTIVE_ICON : INACTIVE_ICON} />
                    </svg>
                    <span class="text-gray-200 text-xs sm:text-sm">{skill.name}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

    </div>
  </div>
</section>
