---
import { skillCategories } from '@/data/skills';

const ACTIVE_ICON =
  'M400 480H48c-26.51 0-48-21.49-48-48V80c0-26.51 21.49-48 48-48h352c26.51 0 48 21.49 48 48v352c0 26.51-21.49 48-48 48zm-204.686-98.059l184-184c6.248-6.248 6.248-16.379 0-22.627l-22.627-22.627c-6.248-6.248-16.379-6.249-22.628 0L184 302.745l-70.059-70.059c-6.248-6.248-16.379-6.248-22.628 0l-22.627 22.627c-6.248 6.248-6.248 16.379 0 22.627l104 104c6.249 6.25 16.379 6.25 22.628.001z';
const INACTIVE_ICON =
  'M400 32H48C21.5 32 0 53.5 0 80v352c0 26.5 21.5 48 48 48h352c26.5 0 48-21.5 48-48V80c0-26.5-21.5-48-48-48z';

const codeLines = [
  { num: 1, content: '/**', type: 'comment' },
  { num: 2, content: '* About Nikhil Patil', type: 'heading' },
  { num: 3, content: '* Full Stack Backend Engineer', type: 'teal' },
  { num: 4, content: '*/', type: 'comment' },
  { num: 5, content: '', type: 'empty' },
  { num: 6, content: 'const specialization = {', type: 'code' },
  { num: 7, content: '  focus: "Backend & Backoffice Systems",', type: 'property' },
  { num: 8, content: '  expertise: [', type: 'property' },
  { num: 9, content: '    "Scalable Architecture",', type: 'string' },
  { num: 10, content: '    "System Design",', type: 'string' },
  { num: 11, content: '    "API Development",', type: 'string' },
  { num: 12, content: '    "Database Optimization",', type: 'string' },
  { num: 13, content: '    "Microservices"', type: 'string' },
  { num: 14, content: '  ],', type: 'property' },
  { num: 15, content: '  education: {', type: 'property' },
  { num: 16, content: '    bachelors: "Engineering - CS",', type: 'property' },
  { num: 17, content: '    masters: "Masters in AI (In Progress)"', type: 'property' },
  { num: 18, content: '  }', type: 'property' },
  { num: 19, content: '}', type: 'code' },
];
---

<section
  id="about"
  class="w-full h-full flex items-center justify-center px-4 md:px-6 lg:px-8 py-4"
  aria-labelledby="about-heading"
>
  <div class="max-w-7xl w-full h-full flex flex-col">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-4 h-full">

      <!-- Code editor card -->
      <div class="bg-vs-bg-card rounded-lg shadow-xl overflow-hidden flex flex-col h-full">
        <div class="bg-vs-bg-card-hover p-2 flex items-center" aria-hidden="true">
          <div class="flex space-x-2">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
          </div>
          <span class="ml-4 text-gray-400 text-sm font-mono">about.ts</span>
        </div>

        <div class="flex-1 overflow-y-auto font-mono text-xs sm:text-sm p-4 sm:p-6" role="region" aria-label="About me">
          <h2 id="about-heading" class="sr-only">About Me</h2>
          {
            codeLines.map((line) => (
              <div class="flex group hover:bg-vs-bg-card-hover transition-colors duration-150 py-0.5">
                <span class="flex-shrink-0 w-8 text-gray-500 opacity-50 select-none">
                  {line.num}
                </span>
                <div class="flex-1 min-w-0">
                  {line.type === 'comment' && (
                    <span class="text-gray-400">{line.content}</span>
                  )}
                  {line.type === 'heading' && (
                    <span class="text-vs-green">{line.content}</span>
                  )}
                  {line.type === 'empty' && (
                    <span></span>
                  )}
                  {line.type === 'code' && (
                    <span class="text-vs-purple">{line.content}</span>
                  )}
                  {line.type === 'property' && (
                    <span class="text-vs-blue">{line.content}</span>
                  )}
                  {line.type === 'string' && (
                    <span class="text-vs-green ml-2">{line.content}</span>
                  )}
                  {line.type === 'teal' && (
                    <span class="text-vs-teal">{line.content}</span>
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Skills panel -->
      <div class="space-y-3 overflow-y-auto pr-2">
        {
          skillCategories.map((category) => (
            <div class="bg-vs-bg-card p-3 rounded-lg shadow-xl">
              <p class="text-gray-400 mb-2 text-xs font-mono border-b border-gray-700 pb-2">
                {category.label}
              </p>
              <ul class="grid grid-cols-1 gap-1 text-xs" role="list">
                {category.skills.map((skill) => (
                  <li class="flex items-center p-1.5 hover:bg-vs-bg-card-hover rounded transition-colors duration-200">
                    <svg
                      stroke="currentColor"
                      fill="currentColor"
                      stroke-width="0"
                      viewBox="0 0 448 512"
                      class:list={[
                        'min-w-[12px] mr-1.5 shrink-0',
                        skill.active ? 'text-vs-teal' : 'text-gray-600',
                      ]}
                      height="0.8em"
                      width="0.8em"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <path d={skill.active ? ACTIVE_ICON : INACTIVE_ICON} />
                    </svg>
                    <span class="text-gray-200">{skill.name}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

    </div>
  </div>
</section>
