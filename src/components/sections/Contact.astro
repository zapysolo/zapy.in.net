---
import { OWNER_EMAIL, OWNER_PHONE, OWNER_LOCATION } from '@/constants';
---

<section
  id="contact"
  class="flex-1 px-4 md:px-6 lg:px-8 py-12 min-h-screen"
  aria-labelledby="contact-heading"
>
  <div class="max-w-7xl mx-auto">
    <h2 id="contact-heading" class="sr-only">Contact</h2>

    <div class="max-w-2xl mx-auto bg-vs-bg p-4 sm:p-6 rounded-lg font-mono text-sm sm:text-base border border-vs-border">
      <div class="space-y-1">
        <p class="text-gray-400">/**</p>
        <p class="text-gray-400">* Contact Information</p>
        <p class="text-vs-accent">* Let's work together!</p>
        <p class="text-gray-400">*/</p>

        <div class="mt-6 space-y-1">
          <p>
            <span class="text-vs-purple">const</span>{' '}
            <span class="text-vs-blue">contactInfo</span> = {'{'}
          </p>

          <p class="ml-4">
            <span class="text-vs-purple">email:</span>{' '}
            <a
              href={`mailto:${OWNER_EMAIL}`}
              class="text-vs-green hover:underline break-all"
              data-track="email-click"
            >"{OWNER_EMAIL}"</a>,
          </p>

          <p class="ml-4">
            <span class="text-vs-purple">phone:</span>{' '}
            <a href={`tel:${OWNER_PHONE.replace(/\s/g, '')}`} class="text-vs-green hover:underline">
              "{OWNER_PHONE}"
            </a>,
          </p>

          <p class="ml-4">
            <span class="text-vs-purple">location:</span>{' '}
            <span class="text-vs-green">"{OWNER_LOCATION}"</span>,
          </p>

          <p>{'}'}</p>
        </div>
      </div>
    </div>
  </div>
</section>
