---
import ProjectCard from './ProjectCard.astro';
import { projects } from '@/data/projects';
---

<section
  id="projects"
  class="w-full h-full flex items-center justify-center px-4 md:px-6 lg:px-8 py-8"
  aria-labelledby="projects-heading"
>
  <div class="max-w-7xl w-full">
    <h2 id="projects-heading" class="sr-only">Projects</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-h-96 overflow-y-auto pr-4">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</section>
