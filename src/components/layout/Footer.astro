---
import SocialLink from '@/components/common/SocialLink.astro';
import { socials } from '@/data/socials';
---

<footer class="fixed bottom-0 left-0 right-0 bg-vs-bg border-t border-vs-border p-4 z-40">
  <div
    class="flex flex-col sm:flex-row justify-between items-center max-w-screen-xl mx-auto gap-4"
  >
    <div class="flex flex-col sm:flex-row items-center gap-2 sm:gap-4 text-sm">
      <span>Find me in:</span>
      <div class="flex gap-4">
        {
          socials.map((social) => (
            <SocialLink
              label={social.label}
              url={social.url}
              trackingName={social.trackingName}
            />
          ))
        }
      </div>
    </div>

    <SocialLink
      label="@nikhilpatil"
      url="https://www.linkedin.com/in/nikhilpatil8217"
      class="text-sm"
    />
  </div>
</footer>
