---
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { formatDate } from '@/utils';
import { SITE_TITLE } from '@/constants';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  readingTime: number;
  ogImage?: string;
}

const { title, description, date, tags, readingTime, ogImage } = Astro.props;
const pageTitle = `${title} | ${SITE_TITLE}`;
const canonicalUrl = Astro.url.href;
---

<BaseLayout
  title={pageTitle}
  description={description}
  ogImage={ogImage}
  canonicalUrl={canonicalUrl}
>
  <Header />

  <main class="max-w-3xl mx-auto px-4 py-12 mt-[60px]">
    <article>
      <header class="mb-10">
        <div class="flex flex-wrap gap-2 mb-4">
          {
            tags.map((tag) => (
              <span class="text-xs bg-vs-bg-hover text-vs-accent px-2 py-1 rounded font-mono">
                #{tag}
              </span>
            ))
          }
        </div>

        <h1 class="text-3xl md:text-4xl font-mono text-white mb-4">{title}</h1>
        <p class="text-vs-text mb-4">{description}</p>

        <div class="flex items-center gap-4 text-vs-text text-sm font-mono border-t border-vs-border pt-4">
          <time datetime={date.toISOString()}>{formatDate(date)}</time>
          <span>&bull;</span>
          <span>{readingTime} min read</span>
        </div>
      </header>

      <div class="prose-vs">
        <slot />
      </div>
    </article>

    <footer class="mt-12 pt-6 border-t border-vs-border">
      <a
        href="/blog"
        class="text-vs-accent hover:underline font-mono text-sm"
      >
        &larr; view all blogs
      </a>
    </footer>
  </main>

  <Footer />
</BaseLayout>
