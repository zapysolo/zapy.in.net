---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import BlogCard from '@/components/sections/BlogCard.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '@/utils';
import { SITE_TITLE } from '@/constants';

const allPosts = await getCollection('blog', ({ data }: any) => !data.draft);
const sortedPosts = allPosts.sort(
  (a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout
  title={`Blog | ${SITE_TITLE}`}
  description="Thoughts on software engineering, web development, and the things I'm learning."
>
  <Header />

  <main class="max-w-3xl mx-auto px-4 py-12 mt-15">
    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-mono text-white mb-3">_blog</h1>
      <p class="text-vs-text">
        Thoughts on software engineering, web development, and the things I'm learning.
      </p>
    </header>

    {
      sortedPosts.length === 0 ? (
        <p class="text-vs-text font-mono text-center py-16">
          // no posts yet — check back soon
        </p>
      ) : (
        <div class="space-y-4">
          {sortedPosts.map(async (post: any) => {
            const { Content } = await post.render();
            const body = post.body ?? '';
            return (
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                tags={post.data.tags}
                slug={post.slug}
                readingTime={getReadingTime(body)}
              />
            );
          })}
        </div>
      )
    }
  </main>

  <Footer />
</BaseLayout>
